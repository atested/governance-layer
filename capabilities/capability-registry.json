{
  "version": "0.1",
  "governance_posture": {
    "mode": "production"
  },
  "tools": [
    {
      "tool": "FS_WRITE",
      "capability_class": "FS_WRITE",
      "risk_level": "HIGH",
      "allow_base_dirs": [
        "__GOV_CANONICAL_REPO_PATH__",
        "__GOV_RUNTIME_PATH__"
      ],
      "deny_hidden_paths": true,
      "deny_overwrite_by_default": true,
      "deny_executable_outputs": true,
      "args": {
        "required": [
          "path",
          "content"
        ],
        "optional": [
          "overwrite",
          "request_executable"
        ]
      },
      "caps": {
        "request_executable_allowed": false
      }
    },
    {
      "tool": "FS_LIST",
      "capability_class": "FS_LIST",
      "risk_level": "MEDIUM",
      "allow_base_dirs": [
        "__GOV_CANONICAL_REPO_PATH__",
        "__GOV_RUNTIME_PATH__"
      ],
      "deny_hidden_paths": true,
      "deny_traversal": true,
      "args": {
        "required": [
          "path"
        ],
        "optional": [
          "max_entries",
          "include_hidden"
        ]
      },
      "caps": {
        "max_entries_default": 100,
        "max_entries_hard": 500,
        "include_hidden_allowed": false
      }
    },
    {
      "tool": "FS_READ",
      "capability_class": "FS_READ",
      "risk_level": "MEDIUM",
      "allow_base_dirs": [
        "__GOV_CANONICAL_REPO_PATH__",
        "__GOV_RUNTIME_PATH__"
      ],
      "deny_hidden_paths": true,
      "deny_traversal": true,
      "max_bytes_default": 4096,
      "max_bytes_hard": 65536,
      "args": {
        "required": [
          "path"
        ],
        "optional": [
          "max_bytes",
          "offset",
          "as_text"
        ]
      },
      "caps": {
        "max_bytes_default": 4096,
        "max_bytes_hard": 65536,
        "offset_min": 0
      }
    }
  ,
    {
      "tool": "FS_MKDIR",
      "capability_class": "FS_MKDIR",
      "risk_level": "HIGH",
      "allow_base_dirs": [
        "__GOV_CANONICAL_REPO_PATH__",
        "__GOV_RUNTIME_PATH__"
      ],
      "deny_hidden_paths": true,
      "deny_traversal": true,
      "deny_overwrite_by_default": false,
      "args": {
        "required": [
          "path"
        ],
        "optional": [
          "parents",
          "exist_ok"
        ]
      },
      "caps": {
        "parents_allowed": true,
        "exist_ok_allowed": true
      }
    },
    {
      "tool": "FS_MOVE",
      "capability_class": "FS_MOVE",
      "risk_level": "HIGH",
      "allow_base_dirs": [
        "__GOV_CANONICAL_REPO_PATH__",
        "__GOV_RUNTIME_PATH__"
      ],
      "deny_hidden_paths": true,
      "deny_traversal": true,
      "args": {
        "required": ["src_path", "dst_path"],
        "optional": ["overwrite"]
      },
      "caps": {
        "overwrite_allowed": false,
        "cross_root_allowed": false,
        "dst_must_be_within_allowlist": true
      }
    },
    {
      "tool": "FS_DELETE",
      "capability_class": "FS_DELETE",
      "risk_level": "HIGH",
      "allow_base_dirs": [
        "__GOV_CANONICAL_REPO_PATH__",
        "__GOV_RUNTIME_PATH__"
      ],
      "deny_hidden_paths": true,
      "deny_traversal": true,
      "args": {
        "required": ["path"],
        "optional": ["recursive"]
      },
      "caps": {
        "recursive_allowed": false,
        "dry_run_supported": false
      }
    },
    {
      "tool": "FS_DELETE_NONEXEC",
      "capability_class": "FS_DELETE_NONEXEC",
      "risk_level": "HIGH",
      "allow_base_dirs": [
        "__GOV_CANONICAL_REPO_PATH__",
        "__GOV_RUNTIME_PATH__"
      ],
      "deny_hidden_paths": true,
      "deny_traversal": true,
      "args": {
        "required": ["path"],
        "optional": []
      },
      "caps": {
        "require_non_executable": true
      }
    },
    {
      "tool": "FS_COPY",
      "capability_class": "FS_COPY",
      "risk_level": "HIGH",
      "allow_base_dirs": [
        "__GOV_CANONICAL_REPO_PATH__",
        "__GOV_RUNTIME_PATH__"
      ],
      "deny_hidden_paths": true,
      "deny_traversal": true,
      "args": {
        "required": ["src_path", "dst_path"],
        "optional": ["overwrite", "recursive"]
      },
      "caps": {
        "overwrite_allowed": false,
        "recursive_dir_copy_allowed": true
      }
    },
    {
      "tool": "INGEST_ARTIFACT",
      "capability_class": "INGEST_ARTIFACT",
      "risk_level": "MEDIUM",
      "allow_base_dirs": [
        "__GOV_CANONICAL_REPO_PATH__",
        "__GOV_RUNTIME_PATH__"
      ],
      "deny_hidden_paths": true,
      "deny_traversal": true,
      "args": {
        "required": [
          "provenance"
        ],
        "optional": [
          "artifact_path",
          "payload_b64"
        ]
      },
      "caps": {
        "max_artifact_bytes": 4096,
        "allow_inline_payload": true,
        "allow_out_path_reference": true
      }
    },
    {
      "tool": "INGEST_TOOL_EVENT",
      "capability_class": "INGEST_TOOL_EVENT",
      "risk_level": "MEDIUM",
      "allow_base_dirs": [
        "__GOV_CANONICAL_REPO_PATH__",
        "__GOV_RUNTIME_PATH__"
      ],
      "deny_hidden_paths": true,
      "deny_traversal": true,
      "args": {
        "required": [
          "tool_event_version",
          "tool_name",
          "tool_params_digest",
          "exit_code",
          "outputs",
          "policy_context_used",
          "provenance"
        ],
        "optional": []
      },
      "caps": {
        "max_event_bytes": 16384,
        "max_outputs": 64
      }
    },
    {
      "tool": "TOOL_REGISTER",
      "capability_class": "TOOL_REGISTER",
      "risk_level": "MEDIUM",
      "allow_base_dirs": [
        "__GOV_CANONICAL_REPO_PATH__",
        "__GOV_RUNTIME_PATH__"
      ],
      "deny_hidden_paths": true,
      "deny_traversal": true,
      "args": {
        "required": [
          "tool_name",
          "tool_version",
          "schema_json",
          "declared_capabilities"
        ],
        "optional": [
          "created_from"
        ]
      },
      "caps": {
        "max_doc_bytes": 32768
      }
    },
    {
      "tool": "FS_PROMOTE",
      "capability_class": "FS_PROMOTE",
      "risk_level": "HIGH",
      "allow_base_dirs": [
        "__GOV_CANONICAL_REPO_PATH__",
        "__GOV_RUNTIME_PATH__"
      ],
      "deny_hidden_paths": true,
      "deny_traversal": true,
      "args": {
        "required": ["src_path", "dst_path"],
        "optional": ["overwrite"]
      },
      "caps": {
        "cross_root_allowed": true,
        "overwrite_allowed": false,
        "root_id_map": {
          "canonical_repo": "__GOV_CANONICAL_REPO_PATH__",
          "runtime": "__GOV_RUNTIME_PATH__"
        },
        "root_pair_allowlist": [
          {"src_root_id": "runtime", "dst_root_id": "canonical_repo"}
        ],
        "allowed_artifact_classes": ["vetted_output", "build_artifact"]
      }
    },
    {
      "tool": "MSG_SEND",
      "capability_class": "MSG_SEND",
      "risk_level": "HIGH",
      "args": {
        "required": [
          "surface_binding_id",
          "mapping_version",
          "canonical_destination",
          "raw_destination_input",
          "opaque_payload"
        ],
        "optional": [
          "audit_scope"
        ]
      },
      "caps": {
        "decision_alphabet": [
          "ALLOW",
          "DENY"
        ],
        "content_visible_to_evaluator": false,
        "canonical_destination_required": true,
        "raw_destination_audit_required": true,
        "opaque_payload_required": true,
        "reply_context_required": false
      }
    },
    {
      "tool": "MSG_REPLY",
      "capability_class": "MSG_REPLY",
      "risk_level": "HIGH",
      "args": {
        "required": [
          "surface_binding_id",
          "mapping_version",
          "canonical_destination",
          "raw_destination_input",
          "opaque_payload",
          "reply_context"
        ],
        "optional": [
          "audit_scope"
        ]
      },
      "caps": {
        "decision_alphabet": [
          "ALLOW",
          "DENY"
        ],
        "content_visible_to_evaluator": false,
        "canonical_destination_required": true,
        "raw_destination_audit_required": true,
        "opaque_payload_required": true,
        "reply_context_required": true
      }
    }
  ]
}

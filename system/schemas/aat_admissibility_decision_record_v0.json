{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AAT Admissibility Decision Record v0",
  "description": "Decision record from AAT validation with reason codes and version bindings",
  "type": "object",
  "required": [
    "adr_version",
    "decision",
    "reason_codes",
    "kernel_status",
    "profile_status",
    "action_kind",
    "enforcement_mode",
    "version_bindings"
  ],
  "additionalProperties": false,
  "properties": {
    "adr_version": {
      "type": "string",
      "enum": ["v0"]
    },
    "decision": {
      "type": "string",
      "enum": ["PASS", "FAIL_NON_ADMISSIBLE", "FAIL_HARD_STOP"]
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^AAT_(K[1-5]|M1|P[1-2]|C[1-3])_[A-Z_]+$"
      }
    },
    "kernel_status": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    },
    "profile_status": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    },
    "action_kind": {
      "type": "string",
      "enum": ["TOOL_EXEC", "FILE_OPERATION", "NETWORK_REQUEST", "MODEL_INVOKE", "CORE_GENERIC"]
    },
    "enforcement_mode": {
      "type": "string",
      "enum": ["REPORT_ONLY", "ENFORCING"]
    },
    "version_bindings": {
      "type": "object",
      "required": ["policy_digest", "validator_digest", "criteria_digest", "aat_suite_digest"],
      "additionalProperties": false,
      "properties": {
        "policy_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "validator_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "criteria_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "aat_suite_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    }
  },
  "field_order": [
    "adr_version",
    "action_kind",
    "decision",
    "enforcement_mode",
    "kernel_status",
    "profile_status",
    "reason_codes",
    "version_bindings"
  ]
}
